# ════════════════════════════════════════════════════════════════════════════════
# PCSCWorkshop — EditorConfig
# ════════════════════════════════════════════════════════════════════════════════
# https://editorconfig.org
#
# Editör ayarlarını proje genelinde standartlaştırır.
# VS, VS Code, CLion, Vim, Emacs ve diğer editörler destekler.
# ════════════════════════════════════════════════════════════════════════════════

root = true

# ── Genel ────────────────────────────────────────────────────────────────────
[*]
indent_style = space
indent_size = 4
tab_width = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# ── C / C++ ──────────────────────────────────────────────────────────────────
[*.{h,hpp,c,cc,cxx,cpp,in,inl}]
indent_style = tab
indent_size = 4
tab_width = 4

# ── Markdown ─────────────────────────────────────────────────────────────────
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

# ── YAML / JSON ─────────────────────────────────────────────────────────────
[*.{yml,yaml,json}]
indent_style = space
indent_size = 2

# ── Visual Studio proje dosyaları ────────────────────────────────────────────
[*.{sln,vcxproj,vcxproj.filters,props}]
indent_style = space
indent_size = 2
end_of_line = crlf

# ── CMake ────────────────────────────────────────────────────────────────────
[CMakeLists.txt, *.cmake]
indent_style = space
indent_size = 4

# ── Makefile ─────────────────────────────────────────────────────────────────
[Makefile]
indent_style = tab
indent_size = 8
