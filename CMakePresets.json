{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },

  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "17",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "base-win",
      "hidden": true,
      "inherits": "base",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" }
    },
    {
      "name": "base-win-ninja",
      "hidden": true,
      "inherits": "base",
      "generator": "Ninja",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" }
    },
    {
      "name": "base-linux",
      "hidden": true,
      "inherits": "base",
      "generator": "Ninja",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" }
    },
    {
      "name": "base-macos",
      "hidden": true,
      "inherits": "base",
      "generator": "Ninja",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Darwin" }
    },
    {
      "name": "win-debug",
      "displayName": "Windows Debug (fast build, /MDd)",
      "inherits": "base-win",
      "binaryDir": "${sourceDir}/build/win-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreadedDebugDLL",
        "SCARDTOOL_ENABLE_LTCG": "OFF",
        "BUILD_TESTING": "ON"
      }
    },
    {
      "name": "win-relwithdebinfo",
      "displayName": "Windows RelWithDebInfo (fast release, /MD)",
      "inherits": "base-win",
      "binaryDir": "${sourceDir}/build/win-relwithdebinfo",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreadedDLL",
        "SCARDTOOL_ENABLE_LTCG": "OFF",
        "BUILD_TESTING": "ON"
      }
    },
    {
      "name": "win-release",
      "displayName": "Windows Release (ship, /MT + LTCG)",
      "inherits": "base-win",
      "binaryDir": "${sourceDir}/build/win-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded",
        "SCARDTOOL_ENABLE_LTCG": "ON",
        "BUILD_TESTING": "OFF"
      }
    },
    {
      "name": "win-release-ninja",
      "displayName": "Windows Release Ninja (ship, /MT + LTCG)",
      "inherits": "base-win-ninja",
      "binaryDir": "${sourceDir}/build/win-release-ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded",
        "SCARDTOOL_ENABLE_LTCG": "ON",
        "BUILD_TESTING": "OFF"
      }
    },
    {
      "name": "linux-debug",
      "displayName": "Linux Debug",
      "inherits": "base-linux",
      "binaryDir": "${sourceDir}/build/linux-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_TESTING": "ON"
      }
    },
    {
      "name": "linux-release",
      "displayName": "Linux Release",
      "inherits": "base-linux",
      "binaryDir": "${sourceDir}/build/linux-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTING": "OFF"
      }
    },
    {
      "name": "linux-relwithdebinfo",
      "displayName": "Linux RelWithDebInfo",
      "inherits": "base-linux",
      "binaryDir": "${sourceDir}/build/linux-relwithdebinfo",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "BUILD_TESTING": "ON"
      }
    },
    {
      "name": "macos-debug",
      "displayName": "macOS Debug",
      "inherits": "base-macos",
      "binaryDir": "${sourceDir}/build/macos-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_TESTING": "ON"
      }
    },
    {
      "name": "macos-release",
      "displayName": "macOS Release",
      "inherits": "base-macos",
      "binaryDir": "${sourceDir}/build/macos-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTING": "OFF"
      }
    }
  ],

  "buildPresets": [
    { "name": "win-debug",           "configurePreset": "win-debug",           "configuration": "Debug" },
    { "name": "win-relwithdebinfo",  "configurePreset": "win-relwithdebinfo",  "configuration": "RelWithDebInfo" },
    { "name": "win-release",         "configurePreset": "win-release",         "configuration": "Release" },
    { "name": "win-release-ninja",   "configurePreset": "win-release-ninja" },
    { "name": "linux-debug",         "configurePreset": "linux-debug" },
    { "name": "linux-release",       "configurePreset": "linux-release" },
    { "name": "linux-relwithdebinfo","configurePreset": "linux-relwithdebinfo" },
    { "name": "macos-debug",         "configurePreset": "macos-debug" },
    { "name": "macos-release",       "configurePreset": "macos-release" }
  ],

  "testPresets": [
    { "name": "win-debug",           "configurePreset": "win-debug",    "output": {"outputOnFailure": true} },
    { "name": "win-relwithdebinfo",  "configurePreset": "win-relwithdebinfo", "output": {"outputOnFailure": true} },
    { "name": "linux-debug",         "configurePreset": "linux-debug",  "output": {"outputOnFailure": true} },
    { "name": "linux-relwithdebinfo","configurePreset": "linux-relwithdebinfo", "output": {"outputOnFailure": true} },
    { "name": "macos-debug",         "configurePreset": "macos-debug",  "output": {"outputOnFailure": true} }
  ]
}
